{
  "manifest_version": 3,
  "name": "Anchor",
  "version": "0.2.0",
  "description": "Anchor focus-session enforcement — URL filter and friendly block page.",
  "permissions": [
    "tabs",
    "webNavigation",
    "storage",
    "identity"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
