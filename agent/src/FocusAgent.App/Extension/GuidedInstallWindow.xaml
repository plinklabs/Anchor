<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FocusAgent.App.Extension.GuidedInstallWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pds="using:PlinkDesignSystem.Controls">

    <!-- #211 guided-install fallback: shown only when the per-user force-install
         policy didn't take (the extension never checked in within the grace
         period). Wears the same DS ink treatment as the join-by-code dialog
         (ANCHOR_BRAND.md §3) — calm, one magenta spark for the single primary
         action (open the store), a quiet on-ink secondary to dismiss. -->
    <Grid Padding="28,24"
          RowSpacing="14"
          Background="{StaticResource PlinkSurfaceInkBrush}">
        <Grid.Resources>
            <Style x:Key="PlinkOnInkSecondaryButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource PlinkSecondaryButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource PlinkOnInkBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="{StaticResource PlinkHairlineOnInkBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- eyebrow: the product mark + a calm, static ping. -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Center">
            <pds:Ping Diameter="12"
                      Mode="Static"
                      OnInk="True"
                      VerticalAlignment="Center" />
            <TextBlock Style="{StaticResource PlinkEyebrowTextStyle}"
                       Foreground="{StaticResource PlinkOnInkBrush}"
                       Text="ANCHOR" />
        </StackPanel>

        <!-- headline: in Fraunces display. Copy localized in code (Localize()). -->
        <TextBlock x:Name="HeadlineText"
                   Grid.Row="1"
                   Style="{StaticResource PlinkDisplaySmallTextStyle}"
                   Foreground="{StaticResource PlinkOnInkBrush}" />

        <!-- supporting line: plain Hanken on ink. -->
        <TextBlock x:Name="BodyText"
                   Grid.Row="2"
                   Style="{StaticResource PlinkBodyLargeTextStyle}"
                   Foreground="{StaticResource PlinkOnInkMutedBrush}"
                   TextWrapping="Wrap" />

        <!-- the spelled-out two-tap instruction, in quiet mono microcopy. -->
        <TextBlock x:Name="StepsText"
                   Grid.Row="3"
                   Style="{StaticResource PlinkLabelTextStyle}"
                   Foreground="{StaticResource PlinkOnInkMutedBrush}"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10">
            <Button x:Name="LaterButton"
                    Style="{StaticResource PlinkOnInkSecondaryButtonStyle}"
                    Click="OnLaterClicked" />
            <!-- OPEN STORE: the single magenta spark — the one primary action. -->
            <Button x:Name="OpenStoreButton"
                    Style="{StaticResource PlinkPrimaryButtonStyle}"
                    Click="OnOpenStoreClicked" />
        </StackPanel>
    </Grid>
</Window>
