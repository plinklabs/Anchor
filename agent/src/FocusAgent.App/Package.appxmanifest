<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap5="http://schemas.microsoft.com/appx/manifest/uap/windows10/5"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap5 rescap">

  <Identity
    Name="net.arcadia.anchor.focusagent"
    Publisher="CN=Arcadia"
    Version="0.1.2.0" />

  <Properties>
    <DisplayName>Anchor Focus Agent</DisplayName>
    <PublisherDisplayName>Arcadia</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
    <Description>Classroom focus agent. Keeps students on allowed apps during a focus session and reports activity to the teacher console.</Description>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.26100.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application
      Id="FocusAgent"
      Executable="FocusAgent.App.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Anchor Focus Agent"
        Description="Classroom focus agent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png"
        BackgroundColor="#1B1B23">
        <uap:DefaultTile
          Square310x310Logo="Assets\Square310x310Logo.png"
          Wide310x150Logo="Assets\Wide310x150Logo.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>
      <!--
        #225: "start the agent at login" has been re-homed to a per-user
        HKCU\Software\Microsoft\Windows\CurrentVersion\Run entry, written/removed
        by the Velopack install/uninstall lifecycle (see Startup\StartupRegistration
        and Program.cs). The agent ships UNPACKAGED via Velopack, so this MSIX-only
        windows.startupTask extension does NOT apply to the shipped build — it is
        kept solely so the legacy MSIX package (where it is the only available
        mechanism) still auto-starts. The Run key is the shipped path.
      -->
      <Extensions>
        <uap5:Extension
          Category="windows.startupTask"
          Executable="FocusAgent.App.exe"
          EntryPoint="Windows.FullTrustApplication">
          <uap5:StartupTask
            TaskId="AnchorFocusAgentStartup"
            Enabled="true"
            DisplayName="Anchor Focus Agent" />
        </uap5:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
    <Capability Name="internetClient" />
  </Capabilities>
</Package>
