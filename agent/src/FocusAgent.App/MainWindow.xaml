<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FocusAgent.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pds="using:PlinkDesignSystem.Controls">

    <!-- AA1 (#173): the agent's MainWindow wears the DS ink treatment — the one
         full-bleed ink surface a student-facing window gets (ANCHOR_BRAND.md §3).
         Fraunces display title, Space Mono labels/status, Hanken body; hairline
         rules instead of shadows; the Ping motif carries connection liveness and
         the heartbeat. magenta stays the single spark (the primary action). -->
    <Grid Background="{StaticResource PlinkSurfaceInkBrush}">
        <Grid.Resources>
            <!-- The DS default (secondary) Button is tuned for the paper surface —
                 ink foreground on a transparent fill — so it's invisible on this
                 ink window. Re-skin the neutral instrument button for on-ink:
                 paper text + an on-ink hairline border (never a shadow, never a
                 colour flip). Inherits the DS mono typography. -->
            <Style x:Key="PlinkOnInkSecondaryButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource PlinkSecondaryButtonStyle}">
                <Setter Property="Foreground" Value="{StaticResource PlinkOnInkBrush}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="{StaticResource PlinkHairlineOnInkBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- DS-5: the one per-product identity element — a thin top rule in
             Anchor's indigo accent (PlinkProductAccentBrush, overridden in
             App.xaml). It never competes with the magenta spark. -->
        <Border Grid.Row="0"
                Height="2"
                Background="{StaticResource PlinkProductAccentBrush}" />

        <StackPanel Grid.Row="1"
                    Padding="40,32"
                    Spacing="20">

            <!-- eyebrow: the product mark + live connection ping. The ping is
                 static when idle/down, pulses while connected (set in code). -->
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
                <pds:Ping x:Name="ConnectionPing"
                          Diameter="14"
                          Mode="Static"
                          OnInk="True"
                          VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource PlinkEyebrowTextStyle}"
                           Foreground="{StaticResource PlinkOnInkBrush}"
                           Text="ANCHOR" />
            </StackPanel>

            <!-- headline: the connection status, in Fraunces display. Text is set
                 (localized) in code on every render — ApplyConnectionSnapshot. -->
            <TextBlock x:Name="StatusText"
                       Style="{StaticResource PlinkDisplaySmallTextStyle}"
                       Foreground="{StaticResource PlinkOnInkBrush}" />

            <!-- supporting detail / next action, in Hanken body on ink -->
            <TextBlock x:Name="DetailText"
                       Style="{StaticResource PlinkBodyLargeTextStyle}"
                       Foreground="{StaticResource PlinkOnInkMutedBrush}"
                       Text="" />

            <!-- session card: hairline panel on the ink surface, shown only
                 while actually in a focus session. -->
            <Border x:Name="SessionPanel"
                    Style="{StaticResource PlinkInkCardStyle}"
                    Visibility="Collapsed">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="SessionLabelText"
                               Style="{StaticResource PlinkLabelStrongTextStyle}"
                               Foreground="{StaticResource PlinkOnInkBrush}" />
                    <TextBlock x:Name="SessionStatusText"
                               Style="{StaticResource PlinkTitleMediumTextStyle}"
                               Foreground="{StaticResource PlinkOnInkBrush}"
                               Text="" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Center">
                        <pds:Ping x:Name="HeartbeatPing"
                                  Diameter="14"
                                  Mode="Static"
                                  OnInk="True"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="HeartbeatText"
                                   Style="{StaticResource PlinkLabelTextStyle}"
                                   Foreground="{StaticResource PlinkOnInkMutedBrush}"
                                   Text="" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- footer: actions. Leave (left) only while in session; Reconnect/Sign in
             (the spark primary) + Close on the right. -->
        <Grid Grid.Row="2"
              Padding="40,0,40,32">
            <Button x:Name="LeaveButton"
                    Style="{StaticResource PlinkOnInkSecondaryButtonStyle}"
                    Click="OnLeaveClicked"
                    HorizontalAlignment="Left"
                    Visibility="Collapsed" />
            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Right">
                <!-- PrimaryButton content is set (localized) in code on every render. -->
                <Button x:Name="PrimaryButton"
                        Style="{StaticResource PlinkPrimaryButtonStyle}"
                        Click="OnPrimaryClicked" />
                <Button x:Name="CloseButton"
                        Style="{StaticResource PlinkOnInkSecondaryButtonStyle}"
                        Click="OnCloseClicked" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
