<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="FocusAgent.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <!-- AF4 (#165): the agent is a student-facing surface, so it wears the DS
         **ink** treatment for its whole life on every machine — fixed, never
         following the OS light/dark setting (ANCHOR_BRAND.md §6). Pinning
         RequestedTheme="Dark" is what stops the system {ThemeResource} brushes
         (and control styles) from flipping with the OS; the windows then back
         themselves with the DS ink brush (PlinkSurfaceInkBrush), not the system
         base brush. Do not remove this or reintroduce a system swap. -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- The whole Plink Labs design-system WinUI binding in one merge
                     (AF3, #164): colour brushes incl. the full ink/on-ink family,
                     the type ramp, control styles, and the bundled brand fonts.
                     The agent's windows are student-facing, so they compose on
                     the DS ink treatment (ANCHOR_BRAND.md §3). -->
                <ResourceDictionary Source="ms-appx:///PlinkDesignSystem/PlinkResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- DS-5: Anchor layers its identity on the foundations by overriding
                 the one per-product accent slot — the deep indigo, on its ink
                 value (#7E80D2, ANCHOR_BRAND.md §2) since the agent renders on
                 ink. Reserved for the product mark and the one identity rule; the
                 magenta spark is untouched. Defined after the merge so it wins
                 over the binding's neutral (ink) default. -->
            <Color x:Key="PlinkProductAccentColor">#FF7E80D2</Color>
            <SolidColorBrush x:Key="PlinkProductAccentBrush" Color="{StaticResource PlinkProductAccentColor}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
