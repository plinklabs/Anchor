{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  // Entra/Azure AD identifiers are environment-specific and MUST NOT be
  // committed. In production they come from Azure App Service application
  // settings (double-underscore form: AzureAd__TenantId, AzureAd__ClientId,
  // AzureAd__Audience, and AzureAd__ClientCredentials for OBO/Graph). Local
  // dev values live in appsettings.Development.json.
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "",
    "ClientId": "",
    "Audience": ""
  },
  // Allowed CORS origins for the dashboard SPA are environment-specific and
  // MUST NOT be committed. In production set them via App Service settings
  // (Cors__AllowedOrigins__0, Cors__AllowedOrigins__1, ...). Local dev values
  // live in appsettings.Development.json.
  "Cors": {
    "AllowedOrigins": []
  },
  "Heartbeat": {
    "IntervalSeconds": 10,
    "TimeoutMultiplier": 2,
    "ScanIntervalSeconds": 5
  },
  "EventRetention": {
    "RawEventDays": 30,
    "PruneIntervalMinutes": 1440,
    "BatchSize": 10000
  }
}
